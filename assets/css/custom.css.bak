.topbar {
    background: var(--color-primary);
    color: #fff;
}

.topbar li {
    font-size: 16px;
    color: #fff;
}

.topbar li a {
    color: #fff;
}

.topbar li i {
    padding-right: 8px;
}

.topbar ul.language li {
    margin-left: 15px;
}

/* HOME */
.home-img-1 img {
    border-radius: 10px;
}
.home-service-1-2 {
    height: 150px; 
    object-fit: cover;
}

/* WHERE WE ADD VALUE */
.industries-area{
    background:#f8f9fc;
}

.industry-card{
    background:#fff;
    padding:35px;
    border-radius:12px;
    height:100%;
    border:1px solid #eee;
    transition:0.3s;
}

.industry-card:hover{
    transform:translateY(-6px);
    box-shadow:0 15px 40px rgba(0,0,0,0.08);
}

.industry-icon{
    width:55px;
    height:55px;
    display:flex;
    align-items:center;
    justify-content:center;
    background:#f1f3f7;
    border-radius:10px;
    margin-bottom:20px;
}

.industry-icon i{
    font-size: 27px;
    color: var(--color-primary);
}

.industry-subtitle{
    font-size:14px;
    font-weight:600;
    color:#777;
    margin-bottom:10px;
}

.industry-card p{
    font-size:15px;
    color:#666;
}

/* TECHNOLOGIES */
.solutions-area{
    padding:100px 0;
    background:#fff;
}

.solution-row{
    display:flex;
    align-items:center;
    gap:60px;
    margin-bottom:90px;
}

.solution-row.reverse{
    flex-direction:row-reverse;
}

.solution-image img{
    width:320px;
    max-width:100%;
}

.solution-category{
    font-size:13px;
    font-weight:600;
    color:#888;
    display:block;
    margin-bottom:6px;
}

.solution-content h3{
    font-size:26px;
    margin-bottom:12px;
}

.solution-content p{
    color:#666;
    margin-bottom:10px;
}

.cta-about {
    font-size: 25px;
}

.footer-contact {
    list-style: none;
    padding-left: 0px;
}

.footer-contact a {
    font-size: 14px;
}